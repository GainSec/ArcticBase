# Arctic Base configuration. Copy to .env and edit.

# Where workbench data lives. In Docker, mount a volume here.
ARCTIC_BASE_DATA=./data

# HTTP host and port. Defaults: 0.0.0.0:2929.
ARCTIC_BASE_HOST=0.0.0.0
ARCTIC_BASE_PORT=2929

# Per-upload size cap in bytes. Default: 2 GB.
ARCTIC_BASE_MAX_UPLOAD_BYTES=2147483648

# Path to the built Svelte SPA. Relative to the backend working dir.
ARCTIC_BASE_FRONTEND_DIST=../frontend/dist
